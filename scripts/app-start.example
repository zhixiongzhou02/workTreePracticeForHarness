#!/usr/bin/env bash

set -euo pipefail

# Phase 2 接入模板：
# 1. 复制本文件为 scripts/app-start
# 2. 按实际应用框架修改启动命令
# 3. 保证应用绑定 dev-up 提供的端口和目录变量

required_vars=(
  REPO_ROOT
  WORKTREE_ID
  APP_PORT
  API_PORT
  METRICS_PORT
  STATE_ROOT
  DATA_ROOT
  CACHE_ROOT
  LOG_ROOT
  TMP_ROOT
)

for var_name in "${required_vars[@]}"; do
  if [[ -z "${!var_name:-}" ]]; then
    printf '缺少必需环境变量 %s。请通过 scripts/dev-up 启动，而不是直接运行应用命令。\n' "$var_name" >&2
    exit 1
  fi
done

cd "$REPO_ROOT"

# 单进程应用示例：
# exec npm run dev -- --port "$APP_PORT"

# 前后端双进程示例：
# trap 'kill 0' EXIT
# npm run api -- --port "$API_PORT" >>"$LOG_ROOT/api.log" 2>&1 &
# exec npm run web -- --port "$APP_PORT"

printf '这里是 scripts/app-start 模板。请根据真实应用替换为实际启动命令。\n' >&2
exit 1
